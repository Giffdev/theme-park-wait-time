# ─────────────────────────────────────────────────────────
# Firebase — Client-side configuration (NEXT_PUBLIC_ prefix)
# Copy this file to .env.local and fill in real values
# from the Firebase Console → Project Settings → Your Apps
# ─────────────────────────────────────────────────────────

# Firebase Web API key
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here

# Auth domain (usually <project-id>.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Cloud Storage bucket (usually <project-id>.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Cloud Messaging sender ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000

# Firebase App ID
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
